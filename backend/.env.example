AI_RATE_LIMIT_RETRY_DELAY_SECONDS=1.0
AI_RATE_LIMIT_MIN_RETRY_DELAY_SECONDS=2.0
HTTP_MAX_CONNECTIONS=10
HTTP_MAX_KEEPALIVE=5
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
REDIS_URL=redis://localhost:6379/0
GENERATION_QUEUE_NAME=generation_tasks
