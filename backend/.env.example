DATABASE_URL=sqlite+aiosqlite:///./aigen.db
# DATABASE_URL=postgresql+asyncpg://aigen:aigen@localhost:5432/aigen
SECRET_KEY=change-me-to-a-random-secret-key
AI_API_URL=https://www.aiartmirror.com/v1
AI_API_KEY=your-api-key-here
AI_TIMEOUT=2400
AI_MAX_CONCURRENT=1000
HTTP_MAX_CONNECTIONS=1200
HTTP_MAX_KEEPALIVE=200
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
REDIS_URL=redis://localhost:6379/0
GENERATION_QUEUE_NAME=generation_tasks
GENERATION_WORKER_CONCURRENCY=100
GENERATION_POLL_INTERVAL=1
GENERATION_MAX_RETRIES=2
GENERATION_TASK_TIMEOUT=3600
GENERATION_PROCESSING_RECOVERY_SECONDS=3900
STORAGE_BACKEND=local
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=auto
S3_PUBLIC_BASE_URL=
MAX_UPLOAD_SIZE=20971520
IMAGE_DIR=static/images
IMAGE_URL_PREFIX=/static/images
UPLOAD_DIR=static/uploads
UVICORN_WORKERS=1
